{
  "name": "@sanity/visual-editing-standalone",
  "version": "0.0.0",
  "description": "Self-contained ESM build of Sanity Visual Editing for non-React applications",
  "keywords": [
    "esm",
    "overlays",
    "presentation",
    "preview",
    "sanity.io",
    "visual-editing"
  ],
  "homepage": "https://github.com/sanity-io/visual-editing/tree/main/packages/visual-editing-standalone#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/visual-editing/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/visual-editing.git",
    "directory": "packages/visual-editing-standalone"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./create-data-attribute": {
      "source": "./src/create-data-attribute.ts",
      "default": "./dist/create-data-attribute/index.js"
    },
    "./enable-visual-editing": {
      "source": "./src/enable-visual-editing.ts",
      "default": "./dist/enable-visual-editing/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./create-data-attribute": "./dist/create-data-attribute/index.js",
      "./enable-visual-editing": "./dist/enable-visual-editing/index.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "pkg build --strict --check --clean && node ./scripts/check-build.mjs",
    "dev": "pkg build --strict",
    "lint": "eslint .",
    "prepack": "turbo run build",
    "test": "vitest --typecheck"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/package.config": "workspace:*",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@sanity/client": "catalog:",
    "@sanity/comlink": "^4.0.1",
    "@sanity/icons": "^5.1.0",
    "@sanity/mutate": "^0.18.1",
    "@sanity/pkg-utils": "catalog:",
    "@sanity/presentation-comlink": "^2.1.0",
    "@sanity/tsconfig": "catalog:",
    "@sanity/types": "catalog:",
    "@sanity/ui": "^3.3.5",
    "@sanity/visual-editing": "workspace:^",
    "@sanity/visual-editing-csm": "workspace:^",
    "@sanity/visual-editing-types": "workspace:^",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-is": "^19.2.0",
    "@vercel/stega": "^1.1.0",
    "dequal": "^2.0.3",
    "es-module-lexer": "^2.3.1",
    "eslint": "^8.57.1",
    "happy-dom": "^18.0.1",
    "lodash-es": "^4.18.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-is": "^19.2.7",
    "rxjs": "^7.8.2",
    "scroll-into-view-if-needed": "^3.1.0",
    "styled-components": "catalog:",
    "typescript": "catalog:",
    "uuid": "13.0.1",
    "valibot": "^1.4.2",
    "vitest": "^3.2.4",
    "xstate": "^5.32.5"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "eslintConfig": {
    "extends": [
      "@repo/eslint-config"
    ],
    "root": true
  },
  "engines": {
    "node": ">=20.19"
  }
}
